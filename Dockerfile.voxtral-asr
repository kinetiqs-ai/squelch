# Dockerfile.voxtral-asr
#
# Experimental isolated Voxtral Realtime ASR image. Keep this separate from the
# working unified Orpheus/Nemotron image because Voxtral Realtime depends on
# newer vLLM realtime/audio support than the pinned Orpheus runtime.
#
# Build:
#   docker build -f Dockerfile.voxtral-asr -t voxtral-asr:realtime .

FROM vllm/vllm-openai:nightly

RUN python3 -m pip install --no-cache-dir --upgrade \
    "mistral-common[audio]>=1.9.0" \
    librosa \
    soundfile \
    soxr \
    websockets

WORKDIR /workspace

ENV HF_HOME=/root/.cache/huggingface
ENV HF_HUB_DISABLE_XET=1
ENV VOXTRAL_MODEL=mistralai/Voxtral-Mini-4B-Realtime-2602
ENV VOXTRAL_HOST=0.0.0.0
ENV VOXTRAL_PORT=8082

ENTRYPOINT []
CMD ["bash", "/workspace/scripts/start_voxtral_asr.sh"]
